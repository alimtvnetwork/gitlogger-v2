flowchart LR
    %% =========================================================
    %%  git-logs REST API — endpoint mind-map
    %%  Each leaf shows:  METHOD  ·  AUTH MECHANISM  ·  CALLER
    %% =========================================================

    ROOT(["<b>git-logs REST API</b><br/><span style='font-size:11px'>/wp-json/git-logs/v1</span>"]):::root

    %% -------- BRANCH 1 — Auth subsystem --------
    ROOT --> AUTH(["<b>auth</b>"]):::branchAuth
    AUTH --> A1["<b>POST /auth/token</b><br/>Plugin-token exchange<br/><i>Anonymous + plugin token body</i><br/><b>Caller:</b> External medium / CI runner"]:::leafAuth
    AUTH --> A2["<b>POST /auth/refresh</b><br/>Rotating refresh<br/><i>Refresh token body (opaque)</i><br/><b>Caller:</b> External medium"]:::leafAuth
    AUTH --> A3["<b>POST /auth/logout</b><br/>Revoke session<br/><i>Bearer JWT (RS256)</i><br/><b>Caller:</b> External medium"]:::leafAuth
    AUTH --> A4["<b>GET /.well-known/jwks.json</b><br/>Public verification keys<br/><i>None (public, cached)</i><br/><b>Caller:</b> Any JWT verifier"]:::leafPublic

    %% -------- BRANCH 2 — Users (admin) --------
    ROOT --> USR(["<b>users</b>"]):::branchUsers
    USR --> U1["<b>POST /users</b><br/>Create + issue plugin token<br/><i>WP cookie+nonce OR App Password</i><br/><b>Caller:</b> WP Admin"]:::leafAdmin
    USR --> U2["<b>GET /users</b><br/>List<br/><i>Bearer JWT + RBAC: UserAdmin</i><br/><b>Caller:</b> WP Admin / Ops"]:::leafAdmin
    USR --> U3["<b>GET PATCH DELETE /users/{id}</b><br/>Single user CRUD<br/><i>Bearer JWT + RBAC: UserAdmin</i><br/><b>Caller:</b> WP Admin"]:::leafAdmin
    USR --> U4["<b>POST /users/{id}/token:rotate</b><br/>Rotate plugin token<br/><i>Bearer JWT + RBAC: UserAdmin</i><br/><b>Caller:</b> WP Admin"]:::leafAdmin

    %% -------- BRANCH 3 — Repositories (allowlist) --------
    ROOT --> REP(["<b>repositories</b>"]):::branchRepos
    REP --> R1["<b>POST /repositories</b><br/>Add to allowlist<br/><i>Bearer JWT + RBAC: RepoAdmin</i><br/><b>Caller:</b> WP Admin"]:::leafRepo
    REP --> R2["<b>GET /repositories</b><br/>List allowlist<br/><i>Bearer JWT + RBAC: RepoAdmin or LogReader</i><br/><b>Caller:</b> WP Admin / Ops"]:::leafRepo
    REP --> R3["<b>GET PATCH DELETE /repositories/{id}</b><br/>Single repo CRUD<br/><i>Bearer JWT + RBAC: RepoAdmin</i><br/><b>Caller:</b> WP Admin"]:::leafRepo
    REP --> R4["<b>POST /repositories/{id}/sender-token:rotate</b><br/>Rotate per-repo HMAC secret<br/><i>Bearer JWT + RBAC: RepoAdmin</i><br/><b>Caller:</b> WP Admin"]:::leafRepo

    %% -------- BRANCH 4 — Logs (push + read) --------
    ROOT --> LOG(["<b>logs</b>"]):::branchLogs
    LOG --> L1["<b>POST /logs/push</b><br/>Ingest CI log batch (≤ 1 MB)<br/><i>Envelope JWT (HS256, per-repo LogSenderToken)<br/>+ allowlist check + rate limit</i><br/><b>Caller:</b> CI runner (GitHub Actions)"]:::leafPush
    LOG --> L2["<b>GET /logs</b><br/>Cursor-paginated list<br/><i>Bearer JWT + RBAC: LogReader (scoped)</i><br/><b>Caller:</b> External medium / dashboard"]:::leafRead
    LOG --> L3["<b>GET /logs/{id}</b><br/>Single entry<br/><i>Bearer JWT + RBAC: LogReader (scoped)</i><br/><b>Caller:</b> External medium / dashboard"]:::leafRead

    %% -------- BRANCH 5 — Audit --------
    ROOT --> AUD(["<b>audit-trail</b>"]):::branchAudit
    AUD --> AT1["<b>GET /audit-trail</b><br/>Paginated audit query<br/><i>Bearer JWT + RBAC: Auditor</i><br/><b>Caller:</b> Compliance / Ops"]:::leafAudit

    %% -------- LEGEND --------
    subgraph LEGEND["<b>Legend — Auth Mechanisms</b>"]
        direction LR
        LG1["<b>Public</b><br/>No auth, edge-cached"]:::leafPublic
        LG2["<b>WP Bridge</b><br/>Cookie+nonce or App Password"]:::leafAdmin
        LG3["<b>Bearer JWT</b><br/>RS256, 24 h TTL, RBAC-gated"]:::leafRead
        LG4["<b>Envelope JWT</b><br/>HS256 per-repo, allowlist-gated"]:::leafPush
    end

    LEGEND -.-> ROOT

